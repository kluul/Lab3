<Window x:Class="Lab3.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Lab3.ViewModels"
        Title="{Binding IsNew, Converter={StaticResource BoolToStringConverter},
                ConverterParameter='Новая задача|Редактирование задачи'}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindowStyle}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="Название *" Style="{StaticResource LabelStyle}"/>
        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="100"
                 Style="{StaticResource InputStyle}"/>
        <TextBlock Text="{Binding TitleError}"
                   Visibility="{Binding TitleError, Converter={StaticResource NullToVisibilityConverter}}"
                   Style="{StaticResource ErrorTextStyle}"/>

        <TextBlock Text="Описание" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="500"
                 AcceptsReturn="True"
                 Height="80"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Style="{StaticResource InputStyle}"/>
        <TextBlock Text="{Binding Description.Length, StringFormat='{}Символов: {0}/500'}"
                   Foreground="{StaticResource SecondaryBrush}"
                   FontSize="11" Margin="0,2,0,0"/>

        <CheckBox Content="Выполнена"
                  IsChecked="{Binding IsCompleted}"
                  Margin="0,16,0,0"
                  Style="{StaticResource CheckBoxStyle}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена"
                    IsCancel="True"
                    Width="90"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,8,0"/>
            <Button Content="Сохранить"
                    IsDefault="True"
                    Width="110"
                    IsEnabled="{Binding IsValid}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
